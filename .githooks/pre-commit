#!/bin/sh
# Pre-commit hook: sort VS Code workspace files and lint staged markdown files.
# Install: git config core.hooksPath .githooks

if [ -f ".vscode/settings.json" ] || [ -f ".vscode/extensions.json" ] || ls .vscode/*-words.txt >/dev/null 2>&1; then
    if command -v pwsh > /dev/null 2>&1; then
        echo "Sorting VS Code workspace files..."
        if ! pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/settings-sort.ps1; then
            echo "Failed to sort VS Code workspace files"
            exit 1
        fi

        # Keep index in sync if a sorter changed any tracked VS Code workspace files.
        if ! git diff --quiet -- .vscode/settings.json .vscode/extensions.json .vscode/*-words.txt; then
            git add .vscode/settings.json .vscode/extensions.json .vscode/*-words.txt
            echo "Sorted and staged VS Code workspace files"
        fi
    else
        echo "pwsh not found; skipping VS Code file sort"
    fi
fi

echo "Running markdown linting..."

if ! command -v npx > /dev/null 2>&1; then
    echo "npx not found. Install Node.js/npm to run markdownlint-cli2"
    exit 1
fi

STAGED_MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$')

if [ -z "$STAGED_MD_FILES" ]; then
    echo "No markdown files to lint"
    exit 0
fi

echo "Linting markdown files:"
echo "$STAGED_MD_FILES"

if git diff --cached --name-only --diff-filter=ACM -z | tr '\0' '\n' | grep '\.md$' | tr '\n' '\0' | xargs -0 npx --no-install markdownlint-cli2 --config .markdownlint.yaml; then
    echo "Markdown linting passed"
    exit 0
else
    echo ""
    echo "Markdown linting failed"
    echo ""
    echo "Common fixes:"
    echo "  - MD013: Line length exceeds 120 characters"
    echo "  - MD040: Fenced code blocks need language specifier"
    echo "  - MD060: Table columns need proper spacing"
    echo ""
    echo "To fix automatically (where possible):"
    echo "  npx --no-install markdownlint-cli2 --config .markdownlint.yaml --fix <file>.md"
    echo ""
    echo "To skip this check (not recommended):"
    echo "  git commit --no-verify"
    exit 1
fi
